# Local SQLite for dev. Swap to a Postgres connection string in production —
# the Prisma schema doesn't rely on any SQLite-only features.
DATABASE_URL="file:./dev.db"

# Server-side only. Never exposed to the client.
GROQ_API_KEY=""

# Optional override; falls back to llama-3.3-70b-versatile in code.
GROQ_MODEL="llama-3.3-70b-versatile"

# NextAuth — used only for the Google OAuth handshake (session strategy: jwt).
# NEXTAUTH_URL must match the deployed origin exactly (no trailing slash).
NEXTAUTH_URL="https://gloss-theta.vercel.app"
NEXTAUTH_SECRET=""

# Google OAuth client (your own, not a shared/hosted one).
# Authorized redirect URI: https://gloss-theta.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cashfree Payment Gateway. return_url/notify_url are built from NEXTAUTH_URL.
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""
CASHFREE_ENV="SANDBOX"

# Resend — sends the daily due-review reminder email and contact-form
# notifications. Sending to real users requires a custom domain verified
# with Resend (SPF/DKIM/DMARC).
RESEND_API_KEY=""
EMAIL_FROM="Gloss <noreply@usegloss.app>"

# Inbox that gets notified when someone submits the contact form.
SUPPORT_EMAIL="gloss.theta@gmail.com"

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` when
# hitting /api/cron/due-reminders. Any random string; set the same value here
# and in Vercel's project env vars.
CRON_SECRET=""
