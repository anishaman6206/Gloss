{
  "manifest_version": 3,
  "name": "Gloss",
  "description": "Look up any word in context while you read — syncs with your Gloss library.",
  "version": "0.1.0",
  "permissions": ["storage", "cookies", "scripting", "activeTab"],
  "host_permissions": ["https://gloss-theta.vercel.app/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["popup.css"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_popup": "popup.html" },
  "icons": { "128": "icon128.png" }
}
