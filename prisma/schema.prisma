generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  picture       String?
  createdAt     DateTime @default(now())

  // Subscription tracking
  subscriptionStatus String   @default("trialing") // trialing | active | past_due | cancelled | expired
  trialEndsAt        DateTime? // set at signup: now + 7 days
  planId             String?   // razorpay plan id
  razorpaySubId      String?   // razorpay subscription id
  currentPeriodEnd   DateTime?

  sessions Session[]
  words    Word[]
  logs     ReviewLog[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Word {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phrase       String
  sentence     String
  definition   String
  partOfSpeech String
  synonyms     String // JSON-encoded string[]
  examples     String // JSON-encoded string[]
  createdAt    DateTime @default(now())
  review       Review?

  @@index([userId])
}

model Review {
  id             String    @id @default(cuid())
  wordId         String    @unique
  word           Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  easeFactor     Float     @default(2.5)
  intervalDays   Int       @default(0)
  repetitions    Int       @default(0)
  nextReviewAt   DateTime  @default(now())
  lastReviewedAt DateTime?
  lapses         Int       @default(0)
}

model ReviewLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordId     String
  quality    Int
  reviewedAt DateTime @default(now())

  @@index([userId])
}

model DefineRateLimit {
  id    String @id @default(cuid())
  ip    String
  date  String // YYYY-MM-DD (UTC)
  count Int    @default(0)

  @@unique([ip, date])
  @@index([date])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
