generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  picture   String?
  createdAt DateTime @default(now())

  // Subscription tracking
  subscriptionStatus String    @default("trialing") // trialing | active | past_due | cancelled | expired
  trialEndsAt        DateTime? // set at signup: now + 7 days
  planId             String? // "monthly" | "yearly" plan key
  currentPeriodEnd   DateTime?
  subscriptionStart  DateTime? // when the current paid period first began
  cancelAtPeriodEnd  Boolean   @default(false) // user cancelled future renewals; access continues until currentPeriodEnd
  cancelledAt        DateTime?

  // Cashfree payment tracking
  cashfreeOrderId   String?
  cashfreePaymentId String?
  paymentStatus     String? // PAID | FAILED | REFUNDED
  paymentMethod     String? // upi | card | netbanking | wallet, from Cashfree's response

  // Due-review reminder emails
  reminderEmailsEnabled Boolean   @default(true)
  lastReminderSentAt    DateTime?

  // Pro-only streak-freeze perk: one skip-day forgiveness, refilled weekly
  streakFreezesAvailable   Int       @default(0)
  streakFreezesRefreshedAt DateTime?

  sessions         Session[]
  words            Word[]
  logs             ReviewLog[]
  freezes          StreakFreeze[]
  describeAttempts DescribeAttempt[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Word {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phrase       String
  sentence     String
  definition   String
  partOfSpeech String
  synonyms     String // JSON-encoded string[]
  examples     String // JSON-encoded string[]
  source       String   @default("scan") // scan | describe
  createdAt    DateTime @default(now())
  review       Review?

  @@index([userId])
}

model Review {
  id             String    @id @default(cuid())
  wordId         String    @unique
  word           Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  easeFactor     Float     @default(2.5)
  intervalDays   Int       @default(0)
  repetitions    Int       @default(0)
  nextReviewAt   DateTime  @default(now())
  lastReviewedAt DateTime?
  lapses         Int       @default(0)
}

model ReviewLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordId     String
  quality    Int
  reviewedAt DateTime @default(now())

  @@index([userId])
}

model StreakFreeze {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateKey   String // YYYY-MM-DD (UTC), the day retroactively marked active
  createdAt DateTime @default(now())

  @@unique([userId, dateKey])
  @@index([userId])
}

model DefineRateLimit {
  id    String @id @default(cuid())
  ip    String
  date  String // YYYY-MM-DD (UTC)
  count Int    @default(0)

  @@unique([ip, date])
  @@index([date])
}

model DescribeRateLimit {
  id     String @id @default(cuid())
  userId String
  date   String // YYYY-MM-DD (UTC)
  count  Int    @default(0)

  @@unique([userId, date])
  @@index([date])
}

model DescribeAttempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageId     String // key into the curated static image set, not a DB relation
  description String
  feedback    String // JSON-encoded DescribeFeedback
  createdAt   DateTime @default(now())

  @@index([userId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}
